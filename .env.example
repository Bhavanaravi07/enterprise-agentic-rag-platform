# Copy to .env and fill in. All values below are safe defaults for local dev;
# the platform runs fully offline (stub LLM + local embeddings) with no keys.

ENVIRONMENT=dev
LOG_LEVEL=INFO

# --- LLM provider: openai | azure | anthropic | gemini ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=...
# GEMINI_API_KEY=...

# --- Vector backend: faiss | pinecone ---
VECTOR_BACKEND=faiss
FAISS_INDEX_PATH=data/faiss.index
EMBEDDING_DIM=1536
# PINECONE_API_KEY=...
# PINECONE_INDEX=enterprise-rag

# --- Datastores ---
DATABASE_URL=postgresql+psycopg://rag:rag@postgres:5432/ragdb
REDIS_URL=redis://redis:6379/0

# --- Retrieval tuning ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K_FINAL=6

# --- Guardrails ---
ENABLE_PII_REDACTION=true
ENABLE_INJECTION_GUARD=true
